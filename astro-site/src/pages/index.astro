<script>
  const input = document.getElementById('search-input');
  const results = document.getElementById('search-results');
  const sections = document.querySelectorAll('section[id]');

  // Build search index from all sections
  const index = [];
  sections.forEach(s => {
    const title = s.querySelector('h1')?.textContent?.trim() || s.id;
    // Get text snippets from paragraphs
    const paragraphs = s.querySelectorAll('p, li, code, h2, h3');
    const text = Array.from(paragraphs).map(p => p.textContent).join(' ');
    index.push({ id: s.id, title, text: text.toLowerCase(), fullText: text });
  });

  function getSnippet(fullText, query, len = 80) {
    const lower = fullText.toLowerCase();
    const idx = lower.indexOf(query.toLowerCase());
    if (idx === -1) return fullText.slice(0, len) + '...';
    const start = Math.max(0, idx - 30);
    const end = Math.min(fullText.length, idx + query.length + 50);
    let snippet = (start > 0 ? '...' : '') + fullText.slice(start, end) + (end < fullText.length ? '...' : '');
    // Bold the match
    const re = new RegExp('(' + query.replace(/[.*+?^${}()|[\]\\]/g, '\\$&') + ')', 'gi');
    snippet = snippet.replace(re, '<span class="text-[#00ffcc] font-bold">$1</span>');
    return snippet;
  }

  input.addEventListener('input', () => {
    const q = input.value.trim();
    if (!q || q.length < 2) {
      results.classList.add('hidden');
      results.innerHTML = '';
      return;
    }

    const matches = index.filter(item =>
      item.title.toLowerCase().includes(q.toLowerCase()) ||
      item.text.includes(q.toLowerCase())
    );

    if (matches.length === 0) {
      results.innerHTML = '<div class="p-4 text-gray-500 text-sm">No results found</div>';
      results.classList.remove('hidden');
      return;
    }

    results.innerHTML = matches.slice(0, 10).map(m => {
      const snippet = getSnippet(m.fullText, q);
      return `
        <a href="#${m.id}" class="block px-4 py-3 hover:bg-[#00ffcc10] border-b border-gray-700 last:border-0 transition-colors" data-search-result>
          <div class="text-[#ffcc00] font-bold text-sm font-['Bangers'] tracking-wide">${m.title}</div>
          <div class="text-gray-400 text-xs mt-1 leading-relaxed">${snippet}</div>
        </a>
      `;
    }).join('');
    results.classList.remove('hidden');

    // Click handler for results
    results.querySelectorAll('[data-search-result]').forEach(a => {
      a.addEventListener('click', () => {
        results.classList.add('hidden');
        input.value = '';
      });
    });
  });

  // Close on click outside
  document.addEventListener('click', (e) => {
    if (!document.getElementById('search-wrapper').contains(e.target)) {
      results.classList.add('hidden');
    }
  });

  // Cmd+K / Ctrl+K to focus
  document.addEventListener('keydown', (e) => {
    if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
      e.preventDefault();
      input.focus();
      input.select();
    }
    if (e.key === 'Escape') {
      results.classList.add('hidden');
      input.value = '';
      input.blur();
    }
  });

  // Mobile menu
  const menuToggle = document.getElementById('menu-toggle');
  const mobileMenu = document.getElementById('mobile-menu');
  const menuBackdrop = document.getElementById('menu-backdrop');

  menuToggle.addEventListener('click', () => {
    mobileMenu.classList.toggle('hidden');
  });
  menuBackdrop.addEventListener('click', () => {
    mobileMenu.classList.add('hidden');
  });
  document.querySelectorAll('.mobile-toc-link').forEach(link => {
    link.addEventListener('click', () => {
      mobileMenu.classList.add('hidden');
    });
  });
</script>

