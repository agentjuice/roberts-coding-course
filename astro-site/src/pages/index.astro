        <h1 class="font-['Bangers'] text-4xl text-[#00ffcc] tracking-wider uppercase mb-4" style="text-shadow: 3px 3px 0px #ff00ff;">
          Combat
        </h1>

        <div class="rounded-xl border-[3px] p-5 my-6" style="border-color: #39ff14; background: #39ff1410;">
