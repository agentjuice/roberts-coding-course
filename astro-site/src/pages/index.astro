    if self.facing == &quot;down&quot;:  ty += 1
    if self.facing == &quot;left&quot;:  tx -= 1
    if self.facing == &quot;right&quot;: tx += 1

    for enemy in enemies:
        if enemy.x == tx and enemy.y == ty:
            enemy.take_damage(3)</code></pre>

        <h3 class="font-['Bangers'] text-xl text-[#ff69b4] mt-8 mb-3">Step 3: Attack animation drawing</h3>

        <p class="text-gray-200 leading-relaxed mb-4">Draw a yellow/orange rectangle on the tile the player is attacking:</p>

        <pre class="bg-[#1a1a2e] border-2 border-[#00ffcc] rounded-xl p-4 mb-4 overflow-x-auto" style="box-shadow: 0 0 15px rgba(0,255,204,0.2);"><code class="text-gray-200 text-sm font-mono">if self.attacking and self.attack_frame &gt; 0:
    tx, ty = self.x, self.y
