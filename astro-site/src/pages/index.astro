        <h2 class="font-['Bangers'] text-2xl text-[#ffcc00] border-b-4 border-dashed border-[#ff00ff30] pb-2 mt-10 mb-4">The Code</h2>

        <pre class="bg-[#1a1a2e] border-2 border-[#00ffcc] rounded-xl p-4 mb-4 overflow-x-auto" style="box-shadow: 0 0 15px rgba(0,255,204,0.2);"><code class="text-gray-200 text-sm font-mono">python3 isometric_game.py</code></pre>

